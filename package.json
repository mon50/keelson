{
  "name": "reforge",
  "version": "0.1.0",
  "description": "Installer CLI for Reforge skills",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "reforge": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "skills/core",
    "skills/templates",
    "skills/runtime"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/bin/cli.js', 0o755)\"",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fs-extra": "^11.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
